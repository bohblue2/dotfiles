 {
    "window.commandCenter": true,
    "terminal.integrated.profiles.windows": {
      "PowerShell": {
        "source": "PowerShell",
        "icon": "terminal-powershell"
      },
      "Command Prompt": {
        "path": [
          "${env:windir}\\Sysnative\\cmd.exe",
          "${env:windir}\\System32\\cmd.exe"
        ],
        "args": [],
        "icon": "terminal-cmd"
      },
      "Git Bash": {
        "source": "Git Bash"
      },
      "Ubuntu-20.04 (WSL)": {
        "path": "C:\\WINDOWS\\System32\\wsl.exe",
        "args": [
          "-d",
          "Ubuntu-20.04"
        ]
      }
    },
    "terminal.integrated.defaultProfile.windows": "Ubuntu-20.04 (WSL)",
    "files.autoSave": "afterDelay",
    "explorer.confirmDragAndDrop": false,
    "notebook.output.textLineLimit": 200,
    "workbench.editorLargeFileConfirmation": 50,
    "remote.autoForwardPortsSource": "hybrid",
    "diffEditor.maxComputationTime": 0,
    "git.openRepositoryInParentFolders": "never",
    "editor.fastScrollSensitivity": 1.5,
    "editor.mouseWheelScrollSensitivity": 10,
    "jupyter.askForKernelRestart": false,
    "cursor.composer.shouldChimeAfterChatFinishes": true,

    "workbench.editorAssociations": {
      "*.md": "vscode.markdown.preview.editor"
    },
    "python.terminal.activateEnvironment": true,
    "files.exclude": {
      "**/__pycache__": true,
      "**/__init__.py": true,
      "**/.venv": true,
      "**/.git": false
    },
    "search.exclude": {
      "**/__pycache__": true,
      "**/__init__.py": true,
      "**/.venv": true,
      "**/.git": true
    },

    "python.languageServer": "None",
    "python.linting.enabled": false,

    "cursorpyright.disableLanguageServices": true,
    "cursorpyright.analysis.typeCheckingMode": "off",
    "cursorpyright.analysis.diagnosticMode": "workspace",
    "cursorpyright.analysis.exclude": [
      "**/.venv/**",
      "**/__pycache__/**",
      "**/.git/**",
      "**/.ruff_cache/**",
      "**/.pytest_cache/**",
      "**/.mypy_cache/**",
      "**/node_modules/**",
      "**/dist/**",
      "**/build/**",
      "**/target/**",
    ],
    "cursorpyright.analysis.useLibraryCodeForTypes": false,
    "cursorpyright.analysis.diagnosticSeverityOverrides": {
      "reportUnusedImport": "warning",
      "reportUnusedVariable": "warning",
      "reportUnusedFunction": "warning",
      "reportUnusedClass": "warning",
      "reportUnusedCallResult": false,
      "reportPossiblyUnboundVariable": false
    },

    "ruff.enable": true,
    "ruff.lint.enable": true,
    "ruff.nativeServer": "on",
    "ruff.lint.ignore": [
      "F821"
    ],
    "ruff.lineLength": 150,

    "[python]": {
      "editor.defaultFormatter": "charliermarsh.ruff",
      "editor.formatOnSave": true,
      "editor.formatOnSaveMode": "modificationsIfAvailable",
      "editor.codeActionsOnSave": {
        "source.organizeImports": "explicit",
        "source.fixAll": "explicit"
      }
    },

    "ty.disableLanguageServices": true,
    "ty.diagnosticMode": "off",
    "ty.showSyntaxErrors": false,

    "errorLens.enabled": false,
    "errorLens.alignMessage": {
      "start": 0,
      "end": 0,
      "minimumMargin": 8,
      "padding": [
        0,
        0
      ],
      "useFixedPosition": true
    },
    "errorLens.messageMaxChars": 500,
    "errorLens.messageTemplate": "$severity [$source] $message",
    "errorLens.excludeBySource": [
      "pylance"
    ],

    "rust-analyzer.cargo.extraEnv": {
      "LIBTORCH": "/home/yeongmin.bae/libtorch",
      "LIBTORCH_LIB": "/home/yeongmin.bae/libtorch",
      "LIBTORCH_INCLUDE": "/home/yeongmin.bae/libtorch",
      "LIBTORCH_BYPASS_VERSION_CHECK": "1"
    },
    "rust-analyzer.restartServerOnConfigChange": true,

    "remote.SSH.remotePlatform": {
      "ssh yeongmin.bae@10.10.0.53": "linux",
      "ssh s": "linux"
    },

    "json.schemaDownload.enable": true,
    "errorLens.enabledDiagnosticLevels": [
      "error",
      "info"
    ],
    "settings.cycle": [
      {
        "id": "toggleCursorPyright",
        "overrideWorkspaceSettings": true,
        "values": [
          {
            "cursorpyright.analysis.typeCheckingMode": "recommended"
          },
          {
            "cursorpyright.analysis.typeCheckingMode": "off"
          }
        ]
      }
    ],
    "git.autofetch": true,
    "workbench.statusBar.visible": false
  }